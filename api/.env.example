APP_NAME=MODIST
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Cairo
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=modist
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@modist.test"
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000
SANCTUM_TOKEN_EXPIRATION=

# Frontend / CORS origin for the Flutter app (web build)
FRONTEND_URL=http://localhost:3000

# OTP password-reset settings
OTP_TTL_MINUTES=10
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5

# Refresh-token lifetime (rotating refresh tokens), in days
AUTH_REFRESH_TTL_DAYS=30

# Multi-tenancy
# Slug of the tenant unauthenticated requests resolve to (single-store default).
DEFAULT_TENANT_SLUG=modist
# Base host for subdomain-based tenant resolution (e.g. api.example.com). Empty disables it.
TENANT_BASE_HOST=

# Default store currency for money math when a tenant has none configured.
DEFAULT_CURRENCY=EGP

VITE_APP_NAME="${APP_NAME}"
