# Base URL for the MODIST Laravel API. In dev, "/api" is proxied to
# http://localhost:8000 by vite.config.ts. Set to your deployed URL in prod.
VITE_API_BASE_URL=/api/v1

# When "true" the dashboard serves realistic in-memory MOCK data and never
# touches the network. Flip to "false" to hit the real Laravel backend.
VITE_USE_MOCK=true
